{
    "id": "tmdb-episode-provider",
    "name": "TMDb Episode Provider",
    "version": "5.0.0",
    "manifestURI": "https://raw.githubusercontent.com/mrquix1/ChangeEpisodeImageProvidePls/main/tmdb-episode-provider.json",
    "language": "typescript",
    "type": "plugin",
    "description": "Replaces TheTVDB episode images with higher quality TMDb images automatically",
    "author": "MrQuix",
    "icon": "https://www.themoviedb.org/assets/2/favicon.ico",
    "website": "https://www.themoviedb.org",
    "readme": "https://raw.githubusercontent.com/mrquix1/ChangeEpisodeImageProvidePls/main/README.md",
    "notes": "Requires a free TMDb API key",
    "lang": "multi",
    "payloadURI": "https://raw.githubusercontent.com/mrquix1/ChangeEpisodeImageProvidePls/main/tmdb-episode-provider.ts",
    "plugin": {
        "version": "1",
        "permissions": {
            "scopes": ["storage"],
            "allow": {
                "networkAccess": {
                    "allowedDomains": ["api.themoviedb.org", "image.tmdb.org"],
                    "reasoning": "Fetching episode data and images from TMDb API"
                }
            }
        }
    }
}
